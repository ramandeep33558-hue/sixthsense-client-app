{
  "expo": {
    "name": "Sixth Sense Psychics",
    "slug": "sixth-sense-psychics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sixthsensepsychics",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B4EAA"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sixthsense.psychics",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Video calls with psychic advisors",
        "NSMicrophoneUsageDescription": "Voice and video calls with advisors",
        "NSPhotoLibraryUsageDescription": "Share photos in chat messages",
        "NSPhotoLibraryAddUsageDescription": "Save session recordings",
        "NSLocationWhenInUseUsageDescription": "Find nearby psychic advisors",
        "NSFaceIDUsageDescription": "Secure login with Face ID",
        "NSUserTrackingUsageDescription": "Personalize your psychic recommendations",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "remote-notification"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6B4EAA"
      },
      "package": "com.sixthsense.psychics",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "Sixth Sense Psychics",
      "shortName": "Sixth Sense",
      "description": "Connect with verified psychic advisors via live chat, phone, or video. Get guidance on love, career, and life.",
      "themeColor": "#6B4EAA",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6B4EAA",
          "sounds": [
            "./assets/sounds/notification.wav"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Video calls with psychic advisors",
          "microphonePermission": "Voice calls with psychic advisors",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Share photos in chat messages"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Voice calls with psychic advisors"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "sixth-sense-psychics"
      }
    }
  }
}
